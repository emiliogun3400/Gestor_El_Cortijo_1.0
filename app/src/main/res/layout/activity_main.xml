<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menú Principal SGOCI"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnEntradas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Registro de Entradas"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnMermas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Control de Mermas"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnExistencias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. Monitor de Existencias"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnKpis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="4. Visualización de KPIs" />

</LinearLayout>